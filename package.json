{
  "name": "yaya-low-code",
  "version": "0.2.0-alpha.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-dev.ps1",
    "build": "pnpm build:web",
    "lint": "pnpm lint:web",
    "codegen:api": "pnpm --dir web codegen:api",
    "dev:web": "pnpm --dir web dev",
    "dev:api": "cd api && cargo run",
    "dev:desktop": "pnpm --dir web desktop:dev",
    "build:web": "pnpm --dir web build",
    "build:desktop": "pnpm --dir web desktop:build",
    "lint:web": "pnpm --dir web lint",
    "check:api": "cargo check --manifest-path api/Cargo.toml"
  }
}
